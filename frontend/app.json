{
  "expo": {
    "name": "EnviroCare",
    "slug": "envirocare",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "envirocare",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Monitor air quality at your location",
        "NSLocationAlwaysUsageDescription": "Track AQI changes in background",
        "NSCameraUsageDescription": "Scan medical prescriptions via OCR",
        "NSPhotoLibraryUsageDescription": "Upload prescription images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Track AQI at your location"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4ADE80"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload prescription images"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
